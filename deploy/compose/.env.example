## MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=jellyfish
MYSQL_USER=jellyfish
MYSQL_PASSWORD=change-me
MYSQL_PORT=3306

## Redis / Celery Broker
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# 如需单独覆盖完整 broker 地址，可设置：
# CELERY_BROKER_URL=redis://redis:6379/0

## Backend
# 可选：如需真实调用大模型，再设置
# OPENAI_API_KEY=

## 安全（可选，留空则不启用，保持向后兼容）
# 访问鉴权令牌：配置后所有 /api/v1 接口需携带；前端会以同一值自动附加 Bearer 头。
# API_AUTH_TOKEN=
# 敏感字段静态加密密钥：配置后供应商 api_key/api_secret 加密落库。
# backend 与 celery-worker 必须使用相同值；一旦用于生产请勿更换。
# FIELD_ENCRYPTION_KEY=

## RustFS (S3 compatible)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
S3_BUCKET_NAME=jellyfish-assets
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001
# 浏览器访问 S3 文件的公网前缀（用于视频/图片直接播放）
S3_PUBLIC_BASE_URL=http://localhost:9000/jellyfish-assets

## Front runtime config (served as /env.js)
# 由于前后端分端口部署，浏览器应访问宿主机的后端地址
BACKEND_URL=http://localhost:8000
