# Jellyfish Backend - 环境变量示例
# 复制为 .env 后按需修改

# 应用
APP_NAME=Jellyfish API
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# 访问鉴权（可选）：
# - 留空时不启用鉴权，行为与历史一致；
# - 配置后，所有 /api/v1 接口需携带匹配令牌，
#   通过 `Authorization: Bearer <token>` 或 `X-API-Key: <token>` 传入；
# - /health、/docs、/openapi.json、/redoc 始终放行。
#   注意：启用后需让前端（或调用方）一并携带该令牌。
# API_AUTH_TOKEN=

# 敏感字段静态加密密钥（可选）：
# - 留空时供应商 api_key / api_secret 仍按明文存储（向后兼容）；
# - 配置后，新写入的敏感字段加密落库，旧明文在下次写入时自动转为密文；
# - 可使用任意字符串，内部会派生为定长密钥；
# - 一旦用于生产数据请勿更换，否则历史密文将无法解密。
# FIELD_ENCRYPTION_KEY=

# 数据库（默认 SQLite 异步）
# DATABASE_URL=sqlite+aiosqlite:///./jellyfish.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jellyfish
# MySQL 示例（使用 aiomysql 驱动）:
# DATABASE_URL=mysql+aiomysql://user:pass@localhost:3306/jellyfish

# 连接池调优（仅对非 SQLite 后端生效）。pool_recycle 需小于数据库 wait_timeout。
# DB_POOL_PRE_PING=true
# DB_POOL_RECYCLE=1800
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30

# Celery 健壮性与生成任务保护
# CELERY_WORKER_PREFETCH_MULTIPLIER=1
# CELERY_TASK_ACKS_LATE=true
# CELERY_WORKER_MAX_TASKS_PER_CHILD=100
# 兜底超时（秒，留空表示沿用任务自身超时）
# CELERY_TASK_TIME_LIMIT=
# CELERY_TASK_SOFT_TIME_LIMIT=
# 对外部生成 API 的全局节流，如 "60/m"；留空表示不限制
# CELERY_TASK_RATE_LIMIT=

# 生成任务表保留期清理（需以 celery worker -B 启用 beat 调度）
# TASK_CLEANUP_ENABLED=true
# TASK_CLEANUP_RETENTION_DAYS=7
# TASK_CLEANUP_INTERVAL_SECONDS=86400

# Redis / Celery Broker
# 默认情况下，若未单独指定 CELERY_BROKER_URL，系统会自动使用以下 Redis 配置拼接：
# redis://[:password@]host:port/db
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# 如需单独覆盖，可直接指定完整 broker URL：
# CELERY_BROKER_URL=redis://localhost:6379/0

# CORS 前端地址（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 图片生成（用于演员/角色/道具/场景/服装/镜头帧图片生成任务）
# IMAGE_API_PROVIDER=openai
# IMAGE_API_BASE_URL=https://example.com/v1/images/generations
# IMAGE_API_KEY=your-image-api-key

# 视频生成（用于 /film/generated_video 等接口）
# VIDEO_API_PROVIDER=openai
# VIDEO_API_BASE_URL=https://example.com/v1/videos/generations
# VIDEO_API_KEY=your-video-api-key

# S3 / 对象存储（素材文件）
# 如使用 AWS S3，可按需填写：
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_REGION_NAME=ap-southeast-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=jellyfish-assets
# 可选统一前缀，方便按环境/项目隔离，如 jellyfish/dev
# S3_BASE_PATH=jellyfish/dev
# 若有 CDN/自定义域名，可配置成 https://cdn.example.com
# S3_PUBLIC_BASE_URL=
